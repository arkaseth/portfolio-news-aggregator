generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Holding {
  id        String   @id @default(uuid())
  ticker    String
  name      String
  type      String   @default("STOCK")
  quantity  Float
  buyPrice  Float
  sector    String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
